# Authentication (Phase 04+)
# DocKhoj enables authentication by default. On a fresh install, visit
# /register first — the very first account becomes the admin. Subsequent
# users require an invite from the admin.
#
# The session cookie (dockhoj_sid) is HttpOnly + SameSite=Lax. Its
# `Secure` flag is off when NODE_ENV=development and on when
# NODE_ENV=production — production deployments MUST serve over HTTPS,
# otherwise browsers will not send the cookie and users will not stay
# logged in.

# OpenAI-compatible API (for chat/RAG answers)
# Supports OpenAI, MiniMax, or any OpenAI-compatible API
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: specify model (defaults to gpt-4o)
LLM_MODEL=gpt-4o

# Optional: explicit LLM context size in tokens. The app tries to read
# this from your chat provider's /v1/models endpoint at boot; if the
# provider doesn't expose it and your model isn't in the built-in
# fallback table, set this to the published window so the SPA can
# render e.g. "gpt-4o · 128K ctx" or "MiniMax-M3 · 1M ctx".
# LLM_CONTEXT_SIZE=128000

# Ollama (for embeddings - runs locally or in Docker)
OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text

# Qdrant (vector database - runs in Docker container)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents
VECTOR_SIZE=768

# Documents root — where uploaded files land on disk.
# Resolution order (matches src/routes/upload.ts):
#   1. $UPLOAD_DIR  if set
#   2. $DOCKHOJ_HOME/documents
#   3. ~/.dockhoj/documents  (default if neither is set)
# Inside Docker, the compose file sets UPLOAD_DIR=/app/documents and
# bind-mounts $DOCKHOJ_HOME/documents there; outside Docker (npm run
# dev), $DOCKHOJ_HOME controls the host path. You almost never need
# to override this — leave it unset.
# UPLOAD_DIR=~/.dockhoj/documents

# Server
PORT=3001

# Chunking — values are in TOKENS (cl100k_base tokenizer, approximate).
# Override only if you know what you're doing.
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CHUNK_MIN_TOKENS=32

# Embedding / chat tuning
EMBEDDING_CONCURRENCY=4
CHAT_HISTORY_MAX_TURNS=20
LOG_CHUNK_PREVIEW_CHARS=200

# Semantic splitting (uses extra embedding calls on oversized chunks)
CHUNK_SEMANTIC_SPLIT=true

# ── OIDC single sign-on (Phase 06) ────────────────────────────────────────
# Optional. When enabled, the login page adds a "Sign in with <Provider>"
# button alongside the password form. Wire up a new provider by running:
#
#   npm run setup-oidc
#
# That script prompts for the discovery URL + client id/secret, validates
# the IdP's metadata, and writes the OIDC_* keys below into this file
# additively (no other lines touched). Re-run it to update.
#
# OIDC_ENABLED=false by default. Existing local accounts keep working
# unchanged — OIDC is additive.
#
# APP_BASE_URL — the public URL where DocKhoj is reachable. Used to
# build the redirect URI the IdP must allowlist.
# APP_BASE_URL=https://dockhoj.example.com
#
# OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER=
#
# OIDC_SCOPES=openid profile email groups
# OIDC_GROUPS_CLAIM=groups
#
# OIDC_ALLOWED_GROUP=         # blank = no gate; or comma-separated group names
# OIDC_ADMIN_GROUP=           # members get role=admin on every login
# OIDC_PROVIDER_NAME=         # display name on the SSO button; default = issuer host
# OIDC_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_post   # or client_secret_basic