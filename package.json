{
  "name": "dockhoj",
  "version": "1.0.0",
  "description": "Self-hosted document indexing and RAG search with OpenAI-compatible API + Qdrant + Ollama",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "setup-ollama": "ollama pull nomic-embed-text"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@qdrant/qdrant-js": "^1.17.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.0.0",
    "gpt-tokenizer": "^3.4.0",
    "mammoth": "^1.8.0",
    "mdast-util-to-string": "^4.0.0",
    "openai": "^4.0.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "uuid": "^11.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
