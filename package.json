{
  "name": "dockhoj",
  "version": "1.0.0",
  "description": "Self-hosted document indexing and RAG search with OpenAI-compatible API + Qdrant + Ollama",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "setup-ollama": "ollama pull nomic-embed-text"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@qdrant/qdrant-js": "^1.17.0",
    "fastify": "^5.0.0",
    "mammoth": "^1.8.0",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^11.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
