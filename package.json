{
  "name": "dockhoj",
  "version": "1.0.0",
  "description": "Self-hosted document indexing and RAG search with OpenAI-compatible API + Qdrant + Ollama",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "npm --prefix web run dev",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc && npm run build:assets",
    "build:assets": "node scripts/copy-assets.mjs",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "setup-ollama": "ollama pull nomic-embed-text",
    "setup-oidc": "tsx scripts/setup-oidc.ts",
    "reset-admin-account": "tsx scripts/reset-admin-account.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@qdrant/qdrant-js": "^1.17.0",
    "@types/mime-types": "^3.0.1",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.0.0",
    "gpt-tokenizer": "^3.4.0",
    "jose": "^5.0.0",
    "mammoth": "^1.8.0",
    "mdast-util-to-string": "^4.0.0",
    "mime-types": "^3.0.2",
    "openai": "^4.0.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "uuid": "^11.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^10.0.3",
    "happy-dom": "^16.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
