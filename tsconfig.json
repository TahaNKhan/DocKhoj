{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*", "src/types.d.ts"],
  "exclude": ["node_modules", "dist"]
}
